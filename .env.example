# Contact360 Admin — Environment Variables
# Copy to .env.local for local development

# GraphQL API base (no trailing slash). Production default in code is https://api.contact360.io.
# For local FastAPI use http://127.0.0.1:8001 — never :3001 (Next dev) or the /graphql rewrite
# proxies to itself and returns 500.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8001

# In development, omit NEXT_PUBLIC_GRAPHQL_URL to use http://localhost:3001/graphql (same-origin;
# next.config rewrites it to GRAPHQL_UPSTREAM_URL). Setting this to api.contact360.io from the
# browser triggers CORS unless the API allows http://localhost:3001.
# NEXT_PUBLIC_GRAPHQL_URL=http://localhost:3001/graphql

# Upstream for dev rewrites only (must not be localhost:3001).
GRAPHQL_UPSTREAM_URL=http://127.0.0.1:8001

# Legacy Django DocsAI (contact360.io/1) — sidebar link + BFF proxy (server-only for BFF).
NEXT_PUBLIC_LEGACY_DOCSAI_URL=http://127.0.0.1:8000
DOCSAI_INTERNAL_URL=http://127.0.0.1:8000

# GraphQL codegen (`npm run codegen`). Prefer local API when developing.
# CODEGEN_SCHEMA_URL=http://127.0.0.1:8001/graphql
# Or: npm run codegen:local

# Payment QR upload (server-only; same as Django DocsAI admin_ops billing settings).
# S3STORAGE_API_URL=https://your-s3storage-host
# S3STORAGE_API_KEY=
# S3STORAGE_API_TIMEOUT=30000
# PAYMENT_QR_BUCKET_ID=optional-fixed-bucket-override
