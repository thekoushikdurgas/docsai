# Contact360 DocsAI Admin — copy to .env and adjust.
# Prefer DJANGO_ENV=development locally; production sets DJANGO_ENV=production.

DJANGO_ENV=development

# Local dev: optional (defaults in development settings). Production/staging: required (32+ chars).
# SECRET_KEY=

DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# Production (EC2 + hostname), comma-separated — e.g. admin.contact360.io,34.201.10.84
# ALLOWED_HOSTS=admin.contact360.io,34.201.10.84,localhost

# HTTPS in production: set SECURE_SSL_REDIRECT=true when TLS terminates at Django or behind HTTPS.
# SECURE_SSL_REDIRECT=false
# When using HTTPS, set CSRF_TRUSTED_ORIGINS with full origins (scheme + host, no path), e.g.:
# CSRF_TRUSTED_ORIGINS=https://admin.contact360.io

# GraphQL gateway — use https://api.contact360.io/graphql in production when the admin site is served over HTTPS (avoids mixed-content issues for any browser-side calls). Local dev often uses http://127.0.0.1:8000/graphql.
GRAPHQL_URL=http://localhost:8001/graphql
GRAPHQL_INTERNAL_TOKEN=

# Production: disable local Django staff fallback unless break-glass (default false in production.py)
# AUTH_FALLBACK_LOCAL=false

LOGS_API_URL=
LOGS_API_KEY=
S3STORAGE_API_URL=
S3STORAGE_API_KEY=
SCHEDULER_URL=
AI_API_URL=
AI_API_KEY=
EMAILCAMPAIGN_URL=
# Optional direct HTTP health probes (same pattern as admin_ops get_system_health). Gateway also exposes GraphQL health.satelliteHealth.
# CONNECTRA_URL=
# EMAIL_SERVER_HEALTH_URL=
# PHONE_SERVER_HEALTH_URL=
# EXTENSION_SERVER_URL=
# MAILVETTER_URL=

SESSION_COOKIE_AGE=86400
SESSION_COOKIE_SECURE=false

# Optional PostgreSQL (otherwise SQLite db.sqlite3)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# CONN_MAX_AGE=60

# Optional Redis cache
# USE_REDIS_CACHE=false
# REDIS_URL=redis://localhost:6379/0

# Optional Sentry
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# API hit tracking (documentation stats)
API_TRACKING_ENABLED=true
API_TRACKING_PATH_PREFIX=/api/v1/

DOCS_AGENT_VERSION=1.0.0
