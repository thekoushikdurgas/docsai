# Contact360 DocsAI Admin — copy to `.env` for local dev.
# Production/staging: keep secrets in `.env.prod` on the server (or export via systemd/k8s).
# Layering: `production.py` / `staging.py` merge `.env` then `.env.prod` into the process
# environment for keys not already set (exported variables always win). See README.md.

DJANGO_ENV=development

# --- Django core ---
# Local dev: optional (development.py supplies a default). Production/staging: required (32+ chars).
SECRET_KEY=b4wCqgFeeN--6iAlj7RklWivuTcg_6NWQwlwPhkUrlY

DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# Production/staging: comma-separated hosts, no spaces — e.g. admin.contact360.io,34.201.10.84

# HTTPS: when true, production/staging enable secure cookies and SSL redirect (see production.py).
# SECURE_SSL_REDIRECT=false

# CSRF for HTTPS: full origins, comma-separated — e.g. https://admin.contact360.io
# CSRF_TRUSTED_ORIGINS=

# --- Gateway & internal APIs ---
# Prefer https://api.contact360.io/graphql when the admin site is served over HTTPS.
GRAPHQL_URL=http://api.contact360.io/graphql

# Logs / s3storage / AI — use real URLs and keys only in `.env` (never commit). Example placeholders:
LOGS_API_URL=http://3.91.83.154:8091
LOGS_API_KEY=bc7a0177de676a8e8bd98c2a0e6f96152b7b1ae1e72eb3d108ed13d5f01fd9bd
S3STORAGE_API_URL=http://3.27.164.107:8087
S3STORAGE_API_KEY=bc7a0177de676a8e8bd98c2a0e6f96152b7b1ae1e72eb3d108ed13d5f01fd9bd
AI_API_URL=https://34.204.0.164:3000
AI_API_KEY=3e6b8811-40c2-46e7-8d7c-e7e038e86071
EMAILCAMPAIGN_URL=http://34.201.10.84

# Optional direct HTTP health probes (admin_ops system health). Uncomment and set as needed.
CONNECTRA_URL=http://13.210.105.146:8000
EMAIL_SERVER_HEALTH_URL=http://16.176.172.50:3000
PHONE_SERVER_HEALTH_URL=http://16.176.172.50:3000
EXTENSION_SERVER_URL=http://34.230.85.238:8092
MAILVETTER_URL=

# --- Storage & SSRF ---
# Prefer gateway s3.deleteFile for deletes when true (operator JWT).
ADMIN_STORAGE_VIA_GATEWAY=true
# Optional CSV of extra allowed hosts for Durgasman outbound requests (e.g. api.stripe.com,.example.com).
# DURGASMAN_ALLOWED_REQUEST_HOSTS=

# --- AWS (direct S3 / documentation JSON store) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=
# S3_DATA_PREFIX=
# S3_DOCUMENTATION_PREFIX=

# --- Auth ---
# Production default false: gateway JWT only. true = break-glass Django staff login.
AUTH_FALLBACK_LOCAL=true

# --- Session ---
SESSION_COOKIE_AGE=86400
SESSION_COOKIE_SECURE=false

# --- Database ---
# Optional PostgreSQL (otherwise SQLite at db.sqlite3).
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# CONN_MAX_AGE=60

# --- Cache ---
# USE_REDIS_CACHE=false
# REDIS_URL=redis://localhost:6379/0
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0

# --- Email (production SMTP; development uses console backend) ---
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=

# --- Observability ---
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Documentation API tracking ---
API_TRACKING_ENABLED=true
API_TRACKING_USER_TYPE_ENABLED=true
API_TRACKING_PATH_PREFIX=/api/v1/

DOCS_AGENT_VERSION=1.0.0
