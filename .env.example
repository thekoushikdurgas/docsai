# ============================================================================
# Django Docs AI Agent - Environment Variables Configuration
# ============================================================================
# 
# Copy this file to .env and fill in your actual values
#   cp .env.example .env
#
# Run validation after setup:
#   python manage.py validate_env
#
# ============================================================================

# ----------------------------------------------------------------------------
# REQUIRED: Django Settings
# ----------------------------------------------------------------------------
# Generate a secret key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-with-generated-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Environment selection (development/staging/production/testing)
DJANGO_ENV=development

# ----------------------------------------------------------------------------
# RECOMMENDED: AWS S3 Configuration (for file storage)
# ----------------------------------------------------------------------------
# Required for S3 integration features (documentation uploads, file storage)
# Leave empty in example files; inject real secrets from env/secret manager.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=
S3_DATA_PREFIX=data/
S3_DOCUMENTATION_PREFIX=documentation/

# ----------------------------------------------------------------------------
# RECOMMENDED: Lambda API Endpoints
# ----------------------------------------------------------------------------
# Required for AI API integration (documentation now uses local/S3/GraphQL)
LAMBDA_AI_API_URL=
LAMBDA_AI_API_KEY=

# ----------------------------------------------------------------------------
# OPTIONAL: Redis Configuration (DISABLED by default - using Local Memory Cache)
# ----------------------------------------------------------------------------
# Cache uses Django LocMemCache (per-process, no Redis) unless enabled below.
# To use Redis: set USE_REDIS_CACHE=True and configure Redis settings.
# USE_REDIS_CACHE=False
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_URL=redis://localhost:6379/0  # Alternative to host/port/db

# ----------------------------------------------------------------------------
# OPTIONAL: OpenAI Configuration
# ----------------------------------------------------------------------------
# Required for AI chat features (falls back to Lambda AI API if not set)
OPENAI_API_KEY=

# ----------------------------------------------------------------------------
# OPTIONAL: Google Gemini Configuration
# ----------------------------------------------------------------------------
GEMINI_API_KEY=

# ----------------------------------------------------------------------------
# OPTIONAL: Appointment360 GraphQL Configuration
# ----------------------------------------------------------------------------
# Note: Authentication uses JWT tokens from login sessions (no API key required)
APPOINTMENT360_GRAPHQL_URL=http://api.contact360.io/graphql
GRAPHQL_TIMEOUT=30
GRAPHQL_MAX_RETRIES=3
GRAPHQL_RETRY_DELAY=1
# Tune timeout/retries if GraphQL timeouts occur frequently (optional)
GRAPHQL_AUTH_ENABLED=True
S3_AUTH_STORAGE_ENABLED=False

# ----------------------------------------------------------------------------
# OPTIONAL: Lambda Logs API Configuration
# ----------------------------------------------------------------------------
# Required for admin logs page when using Lambda logs.api instead of GraphQL.
# When set, admin logs will fetch from Lambda REST API (X-API-Key auth).
# Leave empty to use GraphQL admin.logs fallback.
LOGS_API_URL=
LOGS_API_KEY=

# ----------------------------------------------------------------------------
# OPTIONAL: Job Scheduler (lambda/tkdjob)
# ----------------------------------------------------------------------------
# Required for admin Job Scheduler page. X-API-Key auth.
JOB_SCHEDULER_API_URL=
JOB_SCHEDULER_API_KEY=

# ----------------------------------------------------------------------------
# OPTIONAL: S3 Storage (lambda/s3storage)
# ----------------------------------------------------------------------------
# Required for admin Storage Files page. Buckets are loaded from users API (Admin/SuperAdmin).
S3STORAGE_API_URL=
S3STORAGE_API_KEY=

# ----------------------------------------------------------------------------
# OPTIONAL: Django-Q Configuration
# ----------------------------------------------------------------------------
# Django-Q worker and task queue settings (defaults shown)
DJANGO_Q_WORKERS=4
DJANGO_Q_RECYCLE=500
DJANGO_Q_TIMEOUT=300
DJANGO_Q_RETRY=300
DJANGO_Q_QUEUE_LIMIT=50
DJANGO_Q_BULK=10
DJANGO_Q_SAVE_LIMIT=250
DJANGO_Q_ERROR_LIMIT=250

# ----------------------------------------------------------------------------
# OPTIONAL: Email Configuration
# ----------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ----------------------------------------------------------------------------
# OPTIONAL: Logging Configuration
# ----------------------------------------------------------------------------
LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# OPTIONAL: Application Settings
# ----------------------------------------------------------------------------
TIME_ZONE=UTC
LANGUAGE_CODE=en-us
USE_LOCAL_JSON_FILES=True
SECURE_SSL_REDIRECT=false