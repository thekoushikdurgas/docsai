# Contact360 Admin (DocsAI) Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.

SECRET_KEY=change-me-in-production-use-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,admin.contact360.io,34.201.10.84

# Database
DATABASE_URL=sqlite:///db.sqlite3

# GraphQL Gateway — may be base URL or full endpoint; site root is not a POST target:
#   http://api.contact360.io/  -> normalized to http://api.contact360.io/graphql
GRAPHQL_URL=http://api.contact360.io/graphql
GRAPHQL_INTERNAL_TOKEN=

# When gateway is down, allow Django staff/superuser login (dev only; set False in production)
AUTH_FALLBACK_LOCAL=True

# Logs API (EC2 log.server)
LOGS_API_URL=http://logs:8091
LOGS_API_KEY=

# S3 Storage (EC2 s3storage.server)
S3STORAGE_API_URL=http://s3storage:8087
S3STORAGE_API_KEY=

# Scheduler / Jobs gateway
SCHEDULER_URL=http://api.contact360.io/graphql

# AI service (EC2 ai.server)
AI_API_URL=http://contact_ai:8090
AI_API_KEY=

# Email campaign
EMAILCAMPAIGN_URL=http://emailcampaign:8086

# Admin session cookie
SESSION_COOKIE_AGE=86400
SESSION_COOKIE_SECURE=False

# Docs Agent version
DOCS_AGENT_VERSION=1.0.0
