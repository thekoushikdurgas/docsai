# Contact360 Admin — production (EC2 / PM2)
# Copy: cp .env.production.example .env.production
# Next.js loads .env.production when NODE_ENV=production (next build / next start).

# ── Public URLs (browser + server) ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.contact360.io
NEXT_PUBLIC_GRAPHQL_URL=https://api.contact360.io/graphql

# ── Server listen (PM2 / ecosystem.config.js also reads PORT) ─────────────
PORT=3000

# ── Optional: deploy script hooks (ec2-deploy.sh / ec2-github-deploy.sh) ───
# SKIP_DB_CHECK=1
# API health URL override (default: NEXT_PUBLIC_API_URL + /health)
# API_HEALTH_URL=https://api.contact360.io/health
