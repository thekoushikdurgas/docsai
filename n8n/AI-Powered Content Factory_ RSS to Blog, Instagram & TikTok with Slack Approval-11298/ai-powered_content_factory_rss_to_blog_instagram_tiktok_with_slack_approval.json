    {
      "id": "b9867afb-e1dc-4686-950f-ced13eda1113",
      "name": "Code in JavaScript",
      "type": "n8n-nodes-base.code",
      "position": [
        560,
        496
      ],
      "parameters": {
        "jsCode": "// 3つのデータを1つにまとめ、Slackが壊れないように文字を掃除するコード\nconst items = $input.all();\n\n// 安全な文字に変換する魔法の関数\nfunction clean(text) {\n  if (!text) return \"生成エラー\";\n  // JSON文字にしてから、前後のダブルクォーテーションを外す（改行コードなどをエスケープする）\n  return JSON.stringify(text).slice(1, -1);\n}\n\n// ここで3つのデータを1つに合体！\n// ※順番がズレてもいいように、中身を見て判断するロジックを入れるとなお良しですが、今回は簡易版です\nreturn {\n  // 3つのアイテムを1つの塊にする\n  blog_content: clean(items[0]?.json?.output || \"データなし\"),\n  insta_content: clean(items[1]?.json?.output || \"データなし\"),\n  script_content: clean(items[2]?.json?.output || \"データなし\")\n};"
      },
      "typeVersion": 2
    },
