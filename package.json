{
  "name": "contact360-admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf .next out dist",
    "clean:all": "npm run clean",
    "ci": "npm run lint && npm run typecheck && npm run build",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:local": "graphql-codegen --config codegen.local.ts",
    "health:smoke": "node scripts/health-smoke.mjs",
    "parity:matrix": "node scripts/generate-parity-matrix.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^9.0.1",
    "@mui/x-data-grid": "^9.0.4",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-select": "^2.2.6",
    "clsx": "^2.1.1",
    "framer-motion": "^12.33.0",
    "graphql": "^16.14.0",
    "graphql-request": "^6.1.0",
    "lucide-react": "^0.454.0",
    "next": "^16.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.13.3",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.4",
    "@graphql-codegen/typescript": "^4.1.2",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.0.0",
    "@playwright/test": "^1.49.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3"
  }
}