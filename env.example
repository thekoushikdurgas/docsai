# Django DocsAI Agent - Environment Configuration

# Django Settings
SECRET_KEY=replace-with-generated-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=sqlite:///db.sqlite3
# For PostgreSQL: postgresql://user:password@localhost:5432/docsai

# Documentation storage: S3-only. Local media/ storage has been removed; AWS and S3_* are required for docs data.
# USE_LOCAL_JSON_FILES is deprecated and no longer used.

# AWS S3 Configuration (required for documentation data)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=
S3_DATA_PREFIX=data/
S3_DOCUMENTATION_PREFIX=documentation/

# Lambda API Configuration (documentation uses local/S3/GraphQL; only AI API used)
LAMBDA_AI_API_URL=
LAMBDA_AI_API_KEY=

# OpenAI Configuration
OPENAI_API_KEY=

# Google Gemini AI Configuration
GEMINI_API_KEY=

# Appointment360 GraphQL Configuration
# Note: Authentication uses JWT tokens from login sessions (no API key required)
APPOINTMENT360_GRAPHQL_URL=http://api.contact360.io/graphql
GRAPHQL_TIMEOUT=30
GRAPHQL_ENABLED=False

# Email Configuration (for password reset, etc.)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Optional Lambda-backed admin surfaces (URL and key must be paired)
LOGS_API_URL=
LOGS_API_KEY=
JOB_SCHEDULER_API_URL=
JOB_SCHEDULER_API_KEY=
S3STORAGE_API_URL=
S3STORAGE_API_KEY=

# Static Files
STATIC_URL=/static/
STATIC_ROOT=staticfiles/
MEDIA_URL=/media/
MEDIA_ROOT=media/

# Security
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Logging
LOG_LEVEL=INFO
