{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.contact360.dev/entities/Deal.json",
  "title": "Deal",
  "type": "object",
  "required": ["id", "org_id", "name", "stage", "created_at"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "org_id": { "type": "string", "format": "uuid" },
    "company_id": { "type": "string", "format": "uuid" },
    "primary_contact_id": { "type": "string", "format": "uuid" },
    "owner_user_id": { "type": "string", "format": "uuid" },
    "name": { "type": "string" },
    "stage": { "type": "string" },
    "amount": { "type": "number" },
    "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
    "expected_close_date": { "type": "string", "format": "date" },
    "probability": { "type": "number", "minimum": 0, "maximum": 100 },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "examples": [
    {
      "id": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
      "org_id": "4fa85f64-5717-4562-b3fc-2c963f66afa6",
      "name": "Enterprise rollout",
      "stage": "proposal",
      "amount": 120000,
      "currency": "USD",
      "probability": 60,
      "created_at": "2026-01-01T00:00:00Z"
    }
  ]
}
