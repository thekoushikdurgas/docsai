{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.contact360.dev/entities/BillingLedgerEntry.json",
  "title": "BillingLedgerEntry",
  "type": "object",
  "required": ["id", "org_id", "entry_type", "amount", "currency", "created_at"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "org_id": { "type": "string", "format": "uuid" },
    "entry_type": {
      "type": "string",
      "enum": ["credit_grant", "credit_spend", "invoice", "adjustment", "refund"]
    },
    "amount": { "type": "number" },
    "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
    "credits_delta": { "type": "number", "description": "Signed change in org credit balance" },
    "reference_type": { "type": "string" },
    "reference_id": { "type": "string" },
    "metadata": { "type": "object", "additionalProperties": true },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "examples": [
    {
      "id": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
      "org_id": "4fa85f64-5717-4562-b3fc-2c963f66afa6",
      "entry_type": "credit_spend",
      "amount": 0,
      "currency": "USD",
      "credits_delta": -5,
      "reference_type": "enrichment_job",
      "reference_id": "5fa85f64-5717-4562-b3fc-2c963f66afa6",
      "created_at": "2026-01-01T00:00:00Z"
    }
  ]
}
