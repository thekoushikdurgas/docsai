{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.contact360.dev/events/email.clicked.v1.json",
  "title": "email.clicked payload (v1)",
  "description": "Kafka topic: email.clicked",
  "type": "object",
  "required": ["message_id", "url", "occurred_at"],
  "additionalProperties": false,
  "properties": {
    "message_id": { "type": "string" },
    "campaign_id": { "type": "string", "format": "uuid" },
    "contact_id": { "type": "string", "format": "uuid" },
    "url": { "type": "string", "format": "uri" },
    "link_token": { "type": "string" },
    "occurred_at": { "type": "string", "format": "date-time" }
  },
  "examples": [
    {
      "message_id": "msg_abc123",
      "url": "https://example.com/landing",
      "occurred_at": "2026-01-01T12:05:00Z"
    }
  ]
}
