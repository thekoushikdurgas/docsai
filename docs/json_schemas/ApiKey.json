{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.contact360.dev/entities/ApiKey.json",
  "title": "ApiKey",
  "type": "object",
  "required": ["id", "org_id", "name", "prefix", "scopes", "created_at"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "org_id": { "type": "string", "format": "uuid" },
    "name": { "type": "string" },
    "prefix": { "type": "string", "description": "First chars of key for display" },
    "scopes": { "type": "array", "items": { "type": "string" } },
    "expires_at": { "type": "string", "format": "date-time" },
    "revoked_at": { "type": "string", "format": "date-time" },
    "created_at": { "type": "string", "format": "date-time" },
    "last_used_at": { "type": "string", "format": "date-time" }
  },
  "examples": [
    {
      "id": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
      "org_id": "4fa85f64-5717-4562-b3fc-2c963f66afa6",
      "name": "CI pipeline",
      "prefix": "c360_live_",
      "scopes": ["contacts:read", "campaigns:write"],
      "created_at": "2026-01-01T00:00:00Z"
    }
  ]
}
