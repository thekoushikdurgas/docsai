{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.contact360.dev/entities/Activity.json",
  "title": "Activity",
  "type": "object",
  "required": ["id", "org_id", "type", "created_at"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "org_id": { "type": "string", "format": "uuid" },
    "type": {
      "type": "string",
      "enum": ["note", "call", "email", "meeting", "task", "sms", "linkedin", "system"]
    },
    "subject": { "type": "string" },
    "body": { "type": "string" },
    "contact_id": { "type": "string", "format": "uuid" },
    "company_id": { "type": "string", "format": "uuid" },
    "deal_id": { "type": "string", "format": "uuid" },
    "owner_user_id": { "type": "string", "format": "uuid" },
    "due_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": "string", "format": "date-time" },
    "metadata": { "type": "object", "additionalProperties": true },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "examples": [
    {
      "id": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
      "org_id": "4fa85f64-5717-4562-b3fc-2c963f66afa6",
      "type": "call",
      "subject": "Discovery call",
      "contact_id": "5fa85f64-5717-4562-b3fc-2c963f66afa6",
      "created_at": "2026-01-01T00:00:00Z"
    }
  ]
}
