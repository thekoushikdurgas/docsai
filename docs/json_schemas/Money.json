{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.contact360.dev/shared/Money.json",
  "title": "Money",
  "type": "object",
  "required": ["currency"],
  "additionalProperties": false,
  "properties": {
    "amount_minor": {
      "type": "integer",
      "description": "Minor units (cents) when amount_decimal absent"
    },
    "amount_decimal": { "type": "string", "pattern": "^-?\\d+(\\.\\d+)?$" },
    "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
    "credits": { "type": "number", "description": "Org credit units for metering" }
  },
  "examples": [{ "amount_minor": 9900, "currency": "USD" }]
}
