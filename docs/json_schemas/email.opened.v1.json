{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.contact360.dev/events/email.opened.v1.json",
  "title": "email.opened payload (v1)",
  "description": "Kafka topic: email.opened",
  "type": "object",
  "required": ["message_id", "occurred_at"],
  "additionalProperties": false,
  "properties": {
    "message_id": { "type": "string" },
    "campaign_id": { "type": "string", "format": "uuid" },
    "contact_id": { "type": "string", "format": "uuid" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "user_agent": { "type": "string" },
    "ip_hash": { "type": "string", "description": "Hashed IP for privacy" }
  },
  "examples": [
    {
      "message_id": "msg_abc123",
      "campaign_id": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
      "contact_id": "4fa85f64-5717-4562-b3fc-2c963f66afa6",
      "occurred_at": "2026-01-01T12:00:00Z"
    }
  ]
}
