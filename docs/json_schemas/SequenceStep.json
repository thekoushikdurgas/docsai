{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.contact360.dev/entities/SequenceStep.json",
  "title": "SequenceStep",
  "type": "object",
  "required": ["id", "org_id", "sequence_id", "order_index", "step_type", "created_at"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "org_id": { "type": "string", "format": "uuid" },
    "sequence_id": { "type": "string", "format": "uuid" },
    "order_index": { "type": "integer", "minimum": 0 },
    "step_type": { "type": "string", "enum": ["email", "wait", "task", "condition"] },
    "template_id": { "type": "string", "format": "uuid" },
    "wait_duration_hours": { "type": "integer", "minimum": 0 },
    "condition": { "type": "object", "additionalProperties": true },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "examples": [
    {
      "id": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
      "org_id": "4fa85f64-5717-4562-b3fc-2c963f66afa6",
      "sequence_id": "5fa85f64-5717-4562-b3fc-2c963f66afa6",
      "order_index": 0,
      "step_type": "email",
      "template_id": "6fa85f64-5717-4562-b3fc-2c963f66afa6",
      "created_at": "2026-01-01T00:00:00Z"
    }
  ]
}
