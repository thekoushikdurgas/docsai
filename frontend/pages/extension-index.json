{
  "kind": "extension",
  "title": "Contact360 browser extension UI map",
  "version": "2.0.0",
  "path": "contact360.extension",
  "chrome_min": "114",
  "stack": "Vite + React 18 + TypeScript + @crxjs/vite-plugin",
  "build_output": "contact360.extension/dist",
  "surfaces": [
    {
      "id": "sidepanel",
      "file": "contact360.extension/src/sidebar/index.html",
      "entry": "contact360.extension/src/sidebar/main.tsx",
      "style": "contact360.extension/src/sidebar/styles/sidepanel.css",
      "routes": [
        {
          "id": "capture",
          "component": "src/sidebar/pages/CapturePage.tsx",
          "features": ["pipelineSteps", "PageKindChip", "CaptureCard", "apiHealth"]
        },
        {
          "id": "preview",
          "component": "src/sidebar/pages/PreviewPage.tsx",
          "features": ["PreviewDashboard", "c360_last_capture_preview"]
        },
        {
          "id": "settings",
          "component": "src/sidebar/pages/SettingsPage.tsx",
          "features": ["GraphqlUrlField", "TelemetryToggle", "SnapshotSizeField", "HostScopeOptIn"]
        },
        {
          "id": "account",
          "component": "src/sidebar/pages/AccountPage.tsx",
          "features": ["LoginModal", "AccountChip", "AccountPopover"]
        }
      ]
    }
  ],
  "service_worker": {
    "file": "contact360.extension/src/background/service-worker.ts",
    "modules": [
      "src/background/capturePipeline.ts",
      "src/background/telemetry.ts",
      "src/services/gatewayClient.ts",
      "src/services/graphqlSession.ts"
    ],
    "messages": [
      { "type": "C360_CAPTURE_AND_SAVE", "docs": "docs/backend/endpoints/extension.server/ROUTES.md" },
      { "type": "C360_SCRAPE_ONLY", "docs": "docs/backend/endpoints/extension.server/ROUTES.md" },
      { "type": "C360_GATEWAY_HEALTH", "maps_to": "GET /health" },
      { "type": "C360_AUTH_LOGIN", "docs": "docs/backend/endpoints/contact360.io/AUTH-ENV.md" },
      { "type": "C360_AUTH_LOGOUT", "docs": "docs/backend/endpoints/contact360.io/AUTH-ENV.md" }
    ]
  },
  "content_scripts": [
    {
      "file": "contact360.extension/src/content/index.ts",
      "matches": ["<all_urls>"],
      "message": "C360_SCRAPE_PAGE",
      "notes": "LinkedIn always; other origins require c360_optin_hosts"
    }
  ],
  "api_matrix": [
    {
      "client": "gatewayClient.ts",
      "graphql": [
        "Mutation.salesNavigator.saveSalesNavigatorProfiles",
        "Mutation.salesNavigator.scrapeSalesNavigatorHtml"
      ],
      "rest": ["GET /health"],
      "file": "docs/backend/endpoints/extension.server/ROUTES.md"
    },
    {
      "client": "graphqlSession.ts",
      "graphql": ["Mutation.auth.refreshToken", "Mutation.auth.login", "Mutation.auth.logout"],
      "url": "https://api.contact360.io/graphql",
      "file": "docs/backend/endpoints/contact360.io/GRAPHQL-SCHEMA.md"
    },
    {
      "client": "telemetry.ts",
      "rest": ["POST {logs}/api/v1/logs"],
      "file": "docs/backend/endpoints/log.server/ROUTE-CLIENT-MATRIX.md"
    }
  ]
}
