{
  "kind": "frontend",
  "title": "Contact360 Admin (Next.js) — routes",
  "version": "2.0.0",
  "status": "in_progress",
  "app_path": "contact360.io/admin",
  "legacy_django_path": "contact360.io/1",
  "parity_matrix": "docs/frontend/pages/admin-parity-matrix.json",
  "deploy": {
    "hostname": "admin.contact360.io",
    "ec2_host": "18.207.217.168",
    "port": 3000,
    "pm2": "contact360-admin",
    "legacy_hostname_optional": "docs-admin.contact360.io"
  },
  "routes": [
    {
      "route": "/dashboard",
      "page_title": "Dashboard",
      "notes": "Operator home"
    },
    {
      "route": "/login",
      "page_title": "Login",
      "api_deps": [
        "auth.login pageType admin"
      ]
    },
    {
      "route": "/users",
      "page_title": "Users",
      "api_deps": [
        "admin.users"
      ]
    },
    {
      "route": "/users/[id]",
      "page_title": "User detail + history",
      "api_deps": [
        "admin.users",
        "admin.userHistory"
      ]
    },
    {
      "route": "/billing",
      "page_title": "Billing payments",
      "api_deps": [
        "billing.paymentSubmissions",
        "billing.approvePayment"
      ]
    },
    {
      "route": "/billing/plans",
      "page_title": "Billing plans",
      "api_deps": [
        "billing.plans"
      ]
    },
    {
      "route": "/billing/addons",
      "page_title": "Billing add-ons",
      "api_deps": [
        "billing"
      ]
    },
    {
      "route": "/billing/settings",
      "page_title": "Payment setup",
      "api_deps": [
        "billing"
      ]
    },
    {
      "route": "/jobs",
      "page_title": "Scheduler jobs",
      "api_deps": [
        "admin.schedulerJobs",
        "jobs.retryJob"
      ]
    },
    {
      "route": "/jobs/[id]",
      "page_title": "Job detail",
      "api_deps": [
        "admin.schedulerJobs",
        "jobs"
      ]
    },
    {
      "route": "/jobs/tickets",
      "page_title": "Job tickets",
      "api_deps": [
        "admin.jobTickets"
      ]
    },
    {
      "route": "/logs",
      "page_title": "Logs",
      "api_deps": [
        "admin.logs",
        "admin.deleteLog"
      ]
    },
    {
      "route": "/storage",
      "page_title": "S3 storage",
      "api_deps": [
        "s3.s3Files",
        "s3.deleteFile"
      ]
    },
    {
      "route": "/ai",
      "page_title": "AI chats",
      "api_deps": [
        "aiChats"
      ]
    },
    {
      "route": "/ai/chat",
      "page_title": "AI chat",
      "api_deps": [
        "aiChats",
        "SSE /api/v1/ai-chats"
      ]
    },
    {
      "route": "/ai/sessions",
      "page_title": "AI sessions",
      "api_deps": [
        "aiChats"
      ]
    },
    {
      "route": "/knowledge",
      "page_title": "Knowledge base",
      "api_deps": [
        "knowledge.articles"
      ]
    },
    {
      "route": "/health",
      "page_title": "System health",
      "api_deps": [
        "health.satelliteHealth",
        "health.apiMetadata"
      ]
    },
    {
      "route": "/analytics",
      "page_title": "Analytics",
      "api_deps": [
        "admin.userStats",
        "admin.logStatistics"
      ]
    },
    {
      "route": "/audit",
      "page_title": "Audit events",
      "api_deps": [
        "admin.graphqlAuditEvents"
      ]
    },
    {
      "route": "/ops/contacts",
      "page_title": "Contacts explorer",
      "api_deps": [
        "contacts.contacts"
      ]
    },
    {
      "route": "/ops/campaign-cql",
      "page_title": "Campaign CQL lab",
      "api_deps": [
        "campaignSatellite"
      ]
    },
    {
      "route": "/docs",
      "page_title": "Documentation hub",
      "notes": "BFF → Django /docs/"
    },
    {
      "route": "/durgasflow",
      "page_title": "Durgasflow",
      "notes": "Legacy proxy Phase 5"
    },
    {
      "route": "/durgasman",
      "page_title": "Durgasman",
      "notes": "Legacy proxy Phase 5"
    },
    {
      "route": "/legal/terms",
      "page_title": "Terms",
      "notes": "Public static"
    }
  ]
}