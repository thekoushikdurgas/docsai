{
  "version": "2.0.0",
  "kind": "extension_cross_reference",
  "title": "Contact360 extension — pages, components, services, storage, messages, telemetry",
  "source_root": "contact360.extension/src",
  "pages": [
    {
      "id": "home",
      "component": "src/sidebar/pages/HomePage.tsx",
      "era": "era-04-scrape-preview",
      "web_app_route": "/sales-navigator",
      "phase": "4"
    },
    {
      "id": "capture",
      "component": "src/sidebar/pages/CapturePage.tsx",
      "era": "era-04-scrape-preview",
      "web_app_route": "/sales-navigator",
      "phase": "4"
    },
    {
      "id": "preview",
      "component": "src/sidebar/pages/PreviewPage.tsx",
      "era": "era-04-scrape-preview",
      "web_app_route": "/sales-navigator",
      "phase": "4"
    },
    {
      "id": "apollo",
      "component": "src/sidebar/pages/ApolloPage.tsx",
      "era": "era-04-scrape-preview",
      "web_app_route": "/sales-navigator",
      "phase": "4"
    },
    {
      "id": "settings",
      "component": "src/sidebar/pages/SettingsPage.tsx",
      "era": "era-03-design-system",
      "web_app_route": "/settings",
      "phase": "8"
    },
    {
      "id": "account",
      "component": "src/sidebar/pages/AccountPage.tsx",
      "era": "era-01-auth",
      "web_app_route": "/login",
      "phase": "1"
    }
  ],
  "components": {
    "primitives": [
      { "class": "c360-panel__button", "file": "src/sidebar/components/ui/Button.tsx", "era": "era-03-design-system" },
      { "class": "c360-panel__input", "file": "src/sidebar/components/ui/Input.tsx", "era": "era-03-design-system" },
      { "class": "c360-checkbox", "file": "src/sidebar/components/ui/Checkbox.tsx", "era": "era-03-design-system" },
      { "class": "c360-radio-group", "file": "src/sidebar/components/ui/RadioGroup.tsx", "era": "era-03-design-system" },
      { "class": "c360-radio", "file": "src/sidebar/components/ui/Radio.tsx", "era": "era-03-design-system" },
      { "class": "c360-modal", "file": "src/sidebar/components/ui/Modal.tsx", "era": "era-03-design-system" },
      { "class": "c360-tabs", "file": "src/sidebar/components/ui/Tabs.tsx", "era": "era-03-design-system" },
      { "class": "c360-progress", "file": "src/sidebar/components/ui/Progress.tsx", "era": "era-03-design-system" },
      { "class": "c360-steps", "file": "src/sidebar/components/ui/Steps.tsx", "era": "era-03-design-system" },
      { "class": "c360-card", "file": "src/sidebar/components/ui/Card.tsx", "era": "era-03-design-system" },
      { "class": "c360-empty", "file": "src/sidebar/components/ui/Empty.tsx", "era": "era-03-design-system" },
      { "class": "c360-dash-badge", "file": "src/sidebar/components/ui/Badge.tsx", "era": "era-03-design-system" },
      { "class": "c360-status", "file": "src/sidebar/components/ui/Status.tsx", "era": "era-03-design-system" },
      { "class": "c360-panel__label", "file": "src/sidebar/components/ui/Field.tsx", "era": "era-03-design-system" }
    ],
    "feature": [
      { "name": "CaptureCard", "file": "src/sidebar/components/capture/CaptureCard.tsx" },
      { "name": "PipelineSteps", "file": "src/sidebar/components/capture/PipelineSteps.tsx" },
      { "name": "PreviewDashboard", "file": "src/sidebar/components/preview/PreviewDashboard.tsx" },
      { "name": "EntityList", "file": "src/sidebar/components/entities/EntityList.tsx" },
      { "name": "LoginModal", "file": "src/sidebar/components/auth/LoginModal.tsx" },
      { "name": "HostScopeOptIn", "file": "src/sidebar/components/settings/HostScopeOptIn.tsx" }
    ]
  },
  "services": [
    {
      "module": "src/services/gatewayClient.ts",
      "graphql": [
        "Mutation.salesNavigator.saveSalesNavigatorProfiles",
        "Mutation.salesNavigator.scrapeSalesNavigatorHtml",
        "Mutation.apollo.saveApolloProfiles",
        "Mutation.apollo.scrapeApolloHtml",
        "Query.salesNavigator.entitiesByUuids"
      ],
      "satellite": "extension.server POST /v1/save-profiles, POST /v1/scrape, POST /v1/apollo-scrape",
      "env_docs": "docs/backend/endpoints/extension.server/AUTH-ENV.md"
    },
    {
      "module": "src/services/graphqlSession.ts",
      "graphql": ["Mutation.auth.refreshToken"],
      "env_docs": "docs/backend/endpoints/contact360.io/AUTH-ENV.md"
    },
    {
      "module": "src/background/telemetry.ts",
      "rest": "POST {logs_api}/api/v1/logs",
      "admin": "contact360.io/admin + log.server",
      "env_docs": "docs/backend/endpoints/log.server/AUTH-ENV.md"
    }
  ],
  "storage_keys": [
    { "key": "c360_extension_access_token", "owner": "src/services/graphqlSession.ts", "consumers": ["src/background/service-worker.ts", "src/sidebar/contexts/AuthContext.tsx"] },
    { "key": "c360_extension_refresh_token", "owner": "src/services/graphqlSession.ts", "consumers": ["src/background/service-worker.ts"] },
    { "key": "c360_graphql_url", "owner": "src/background/service-worker.ts", "consumers": ["src/sidebar/contexts/SettingsContext.tsx"] },
    { "key": "c360_optin_hosts", "owner": "src/content/index.ts", "consumers": ["src/sidebar/components/settings/HostScopeOptIn.tsx"] },
    { "key": "c360_last_capture_preview", "owner": "src/background/capturePipeline.ts", "consumers": ["src/sidebar/hooks/useLastCapture.ts"] },
    { "key": "c360_last_capture_entities", "owner": "src/background/capturePipeline.ts", "consumers": ["src/sidebar/hooks/useLastCaptureEntities.ts", "src/sidebar/pages/HomePage.tsx"] },
    { "key": "c360_telemetry_enabled", "owner": "src/background/telemetry.ts", "consumers": ["src/sidebar/pages/SettingsPage.tsx"] }
  ],
  "messages": [
    { "type": "C360_AUTH_LOGIN", "handler": "src/background/service-worker.ts", "sender": "src/sidebar/contexts/AuthContext.tsx" },
    { "type": "C360_AUTH_LOGOUT", "handler": "src/background/service-worker.ts", "sender": "src/sidebar/contexts/AuthContext.tsx" },
    { "type": "C360_GATEWAY_HEALTH", "handler": "src/background/service-worker.ts", "sender": "src/sidebar/hooks/useApiHealth.ts" },
    { "type": "C360_CAPTURE_AND_SAVE", "handler": "src/background/service-worker.ts", "sender": "src/sidebar/contexts/CaptureContext.tsx" },
    { "type": "C360_SCRAPE_PAGE", "handler": "src/content/index.ts", "sender": "src/background/capturePipeline.ts" },
    { "type": "C360_SCRAPE_APOLLO", "handler": "src/content/index.ts", "sender": "src/background/apolloPipeline.ts" },
    { "type": "C360_APOLLO_RUN", "handler": "src/background/service-worker.ts", "sender": "src/sidebar/pages/ApolloPage.tsx" },
    { "type": "C360_SCRAPE_ONLY", "handler": "src/background/service-worker.ts", "sender": "legacy / optional" }
  ],
  "telemetry_fields_v2": [
    "extension_version",
    "manifest_version",
    "request_id",
    "telemetry_schema_version",
    "graphql_url",
    "host_scope",
    "page_kind",
    "latency_ms"
  ],
  "flowcharts": [
    { "file": "docs/flowchart/extension-capture.md", "era": "era-07-flow-docs" },
    { "file": "docs/flowchart/extension-generic-capture.md", "era": "era-07-flow-docs" }
  ]
}
