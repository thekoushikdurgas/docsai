// ============================================================
// Contact360 — Prisma Schema
// Engine: PostgreSQL 16 + pgvector
// Version: 1.0 · April 2026
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "fullTextSearch", "fullTextIndex", "relationJoins"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuidOssp(map: "uuid-ossp"), pgvector(map: "vector"), pgcrypto]
}

// ============================================================
// ENUMS
// ============================================================

enum OrgPlan {
  TRIAL
  STARTER
  PRO
  ENTERPRISE
}

enum UserRole {
  ADMIN
  MANAGER
  USER
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  INVITED
}

enum ContactStatus {
  LEAD
  PROSPECT
  CUSTOMER
  CHURNED
  UNSUBSCRIBED
}

enum ContactSource {
  EXTENSION
  IMPORT
  MANUAL
  API
  ENRICHMENT
  INTEGRATION
}

enum EmailStatus {
  VALID
  RISKY
  INVALID
  UNKNOWN
  UNVALIDATED
}

enum DealStage {
  LEAD
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum DealStatus {
  OPEN
  WON
  LOST
  STALLED
}

enum CampaignType {
  EMAIL
  SMS
  WHATSAPP
  TELEGRAM
  LINKEDIN
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  PAUSED
  CANCELLED
}

enum JobType {
  IMPORT
  EXPORT
  ENRICH_EMAIL
  ENRICH_PHONE
  VALIDATE_EMAIL
  VALIDATE_PHONE
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum JobLogLevel {
  INFO
  WARN
  ERROR
  DEBUG
}

enum IntegrationType {
  GMAIL
  OUTLOOK
  WHATSAPP
  TELEGRAM
  SLACK
  SALESFORCE
  HUBSPOT
  ZAPIER
}

enum IntegrationStatus {
  ACTIVE
  INACTIVE
  ERROR
  PENDING_AUTH
}

enum AiActionStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  EXECUTING
  COMPLETED
  FAILED
}

enum AuditSeverity {
  INFO
  WARNING
  HIGH
  CRITICAL
}

// ============================================================
// 1. CORE TENANCY & USERS
// ============================================================

model Organization {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  slug      String   @unique
  plan      OrgPlan  @default(TRIAL)
  credits   Int      @default(500)
  settings  Json     @default("{}")

  // Billing
  stripeCustomerId String?
  trialEndsAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users              User[]
  contacts           Contact[]
  companies          Company[]
  deals              Deal[]
  campaigns          Campaign[]
  emailTemplates     EmailTemplate[]
  campaignTemplates  CampaignTemplate[]
  emailPatterns      EmailPattern[]
  emailValidations   EmailValidation[]
  phoneValidations   PhoneValidation[]
  files              File[]
  jobs               Job[]
  bqlQueries         BqlQuery[]
  aiQueries          AiQuery[]
  aiActions          AiAction[]
  integrations       Integration[]
  providerAccounts   ProviderAccount[]
  extensionEvents    ExtensionEvent[]
  apiKeys            ApiKey[]
  auditLogs          AuditLog[]
  contactEmbeddings  ContactEmbedding[]

  @@map("organizations")
}

model User {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String     @db.Uuid
  email        String
  name         String
  avatarUrl    String?
  passwordHash String?
  role         UserRole   @default(USER)
  status       UserStatus @default(INVITED)

  // MFA
  mfaEnabled Boolean @default(false)
  mfaSecret  String?

  // OAuth
  googleId   String?
  microsoftId String?

  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  org              Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  ownedContacts    Contact[]         @relation("ContactOwner")
  ownedDeals       Deal[]            @relation("DealOwner")
  bqlQueries       BqlQuery[]
  aiQueries        AiQuery[]
  files            File[]
  extensionEvents  ExtensionEvent[]
  apiKeys          ApiKey[]
  auditLogs        AuditLog[]

  @@unique([orgId, email])
  @@index([orgId])
  @@index([email])
  @@map("users")
}

model ApiKey {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String    @db.Uuid
  createdById String    @db.Uuid
  name        String
  keyHash     String
  keyPreview  String
  environment String    @default("live")
  scopes      String[]  @default([])
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy User         @relation(fields: [createdById], references: [id])

  @@index([orgId])
  @@map("api_keys")
}

// ============================================================
// 2. CRM CORE — CONTACTS & COMPANIES
// ============================================================

model Company {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String   @db.Uuid
  name        String
  domain      String?
  industry    String?
  sizeRange   String?
  size        Int?
  linkedinUrl String?
  website     String?
  country     String?
  city        String?
  tags        String[] @default([])
  customFields Json    @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contacts Contact[]
  deals    Deal[]

  @@unique([orgId, domain])
  @@index([orgId])
  @@map("companies")
}

model Contact {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String        @db.Uuid
  ownerId   String?       @db.Uuid
  companyId String?       @db.Uuid

  // Identity
  firstName String?
  lastName  String?
  fullName  String?
  email     String?
  emailStatus     EmailStatus @default(UNVALIDATED)
  emailConfidence Int?
  phone           String?
  phoneDnd        Boolean     @default(false)

  // Professional
  jobTitle    String?
  department  String?
  linkedinUrl String?
  twitterUrl  String?
  website     String?
  address     String?
  city        String?
  country     String?

  // CRM
  status       ContactStatus @default(LEAD)
  source       ContactSource @default(MANUAL)
  leadScore    Int           @default(0)
  tags         String[]      @default([])
  customFields Json          @default("{}")

  // Enrichment
  enrichedAt      DateTime?
  enrichmentScore Int?

  // Compliance
  unsubscribed   Boolean   @default(false)
  unsubscribedAt DateTime?
  gdprConsent    Boolean   @default(false)
  ccpaOptOut     Boolean   @default(false)

  // Audit
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  org               Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner             User?              @relation("ContactOwner", fields: [ownerId], references: [id])
  company           Company?           @relation(fields: [companyId], references: [id])
  deals             Deal[]
  emailLogs         EmailLog[]
  campaignTargets   CampaignTarget[]
  phoneSearchLogs   PhoneSearchLog[]
  extensionEvents   ExtensionEvent[]
  embeddings        ContactEmbedding[]
  activities        ContactActivity[]

  @@index([orgId])
  @@index([orgId, email])
  @@index([orgId, leadScore(sort: Desc)])
  @@index([orgId, status])
  @@map("contacts")
}

model ContactActivity {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String   @db.Uuid
  contactId   String   @db.Uuid
  type        String   // email_sent, call_made, meeting_scheduled, note_added
  summary     String?
  metadata    Json     @default("{}")
  occurredAt  DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([orgId, occurredAt(sort: Desc)])
  @@map("contact_activities")
}

// pgvector embeddings — raw SQL only (Prisma doesn't support vector natively)
// Managed via $executeRaw in ContactEmbeddingRepository
model ContactEmbedding {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @db.Uuid
  contactId String   @db.Uuid
  type      String   // profile | activity_summary | notes
  content   String
  // embedding vector(1536) — managed via raw SQL migration
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("contact_embeddings")
}

// ============================================================
// 3. DEALS / PIPELINE
// ============================================================

model Deal {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String     @db.Uuid
  contactId   String     @db.Uuid
  companyId   String?    @db.Uuid
  ownerId     String?    @db.Uuid
  title       String
  value       Decimal?   @db.Decimal(14, 2)
  currency    String     @default("INR")
  stage       DealStage  @default(LEAD)
  status      DealStatus @default(OPEN)
  probability Int?
  closeDate   DateTime?
  closedAt    DateTime?
  notes       String?
  tags        String[]   @default([])
  customFields Json      @default("{}")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact Contact      @relation(fields: [contactId], references: [id])
  company Company?     @relation(fields: [companyId], references: [id])
  owner   User?        @relation("DealOwner", fields: [ownerId], references: [id])

  @@index([orgId, stage])
  @@index([contactId])
  @@map("deals")
}

// ============================================================
// 4. EMAIL SYSTEM
// ============================================================

model EmailPattern {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @db.Uuid
  domain    String
  pattern   String   // {first}.{last}@{domain}
  priority  Int      @default(0)
  hitCount  Int      @default(0)
  createdAt DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, domain])
  @@map("email_patterns")
}

model EmailValidation {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String      @db.Uuid
  email       String
  status      EmailStatus @default(UNKNOWN)
  isValid     Boolean?
  isCatchAll  Boolean     @default(false)
  isDisposable Boolean    @default(false)
  mxFound     Boolean     @default(false)
  smtpVerified Boolean    @default(false)
  provider    String?
  score       Float?
  checkedAt   DateTime    @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, email])
  @@index([orgId])
  @@map("email_validations")
}

model EmailLog {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId      String    @db.Uuid
  contactId  String?   @db.Uuid
  campaignId String?   @db.Uuid
  email      String
  subject    String?
  status     String    // sent, delivered, bounced, failed
  provider   String?
  messageId  String?
  sentAt     DateTime  @default(now())

  org        Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact    Contact?          @relation(fields: [contactId], references: [id])
  campaign   Campaign?         @relation(fields: [campaignId], references: [id])
  engagement EmailEngagement?

  @@index([orgId, campaignId])
  @@index([contactId])
  @@map("email_logs")
}

model EmailEngagement {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  emailLogId String    @unique @db.Uuid
  opened     Boolean   @default(false)
  clicked    Boolean   @default(false)
  replied    Boolean   @default(false)
  openedAt   DateTime?
  clickedAt  DateTime?
  repliedAt  DateTime?
  openCount  Int       @default(0)
  clickCount Int       @default(0)

  emailLog EmailLog @relation(fields: [emailLogId], references: [id], onDelete: Cascade)

  @@map("email_engagements")
}

// ============================================================
// 5. PHONE SYSTEM
// ============================================================

model PhoneValidation {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String   @db.Uuid
  phone       String
  countryCode String?
  isValid     Boolean?
  isDnd       Boolean  @default(false)
  carrier     String?
  lineType    String?  // mobile, landline, voip
  provider    String?
  checkedAt   DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, phone])
  @@index([orgId])
  @@map("phone_validations")
}

model PhoneSearchLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @db.Uuid
  contactId String?  @db.Uuid
  query     String
  result    Json?
  provider  String?
  createdAt DateTime @default(now())

  contact Contact? @relation(fields: [contactId], references: [id])

  @@index([orgId])
  @@map("phone_search_logs")
}

// ============================================================
// 6. CAMPAIGN SYSTEM
// ============================================================

model Campaign {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String         @db.Uuid
  createdById String?        @db.Uuid
  name        String
  type        CampaignType
  status      CampaignStatus @default(DRAFT)
  goal        String?

  // Audience
  audienceFilter Json    @default("{}")
  audienceCount  Int?

  // Scheduling
  scheduledAt  DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  sendRate     Int       @default(50)

  // Denormalised stats (updated via DB trigger)
  stats Json @default("{\"sent\":0,\"delivered\":0,\"opened\":0,\"clicked\":0,\"replied\":0,\"bounced\":0,\"unsubscribed\":0,\"spam\":0}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  org          Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  targets      CampaignTarget[]
  messages     CampaignMessage[]
  emailLogs    EmailLog[]
  events       CampaignEvent[]

  @@index([orgId, status])
  @@map("campaigns")
}

model CampaignTarget {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId String @db.Uuid
  contactId  String @db.Uuid
  status     String @default("pending") // pending, sent, skipped

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  Contact  @relation(fields: [contactId], references: [id])

  @@unique([campaignId, contactId])
  @@index([campaignId])
  @@map("campaign_targets")
}

model CampaignMessage {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId String  @db.Uuid
  channel    String
  templateId String? @db.Uuid
  subject    String?
  content    String?
  delayDays  Int     @default(0)
  order      Int     @default(0)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("campaign_messages")
}

model CampaignEvent {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId      String   @db.Uuid
  campaignId String   @db.Uuid
  contactId  String?  @db.Uuid
  event      String   // delivered, opened, clicked, replied, bounced, spam
  linkUrl    String?
  ipAddress  String?
  userAgent  String?
  metadata   Json     @default("{}")
  occurredAt DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, event])
  @@index([contactId])
  @@map("campaign_events")
}

// ============================================================
// 7. TEMPLATES
// ============================================================

model EmailTemplate {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @db.Uuid
  name      String
  subject   String?
  bodyHtml  String?
  bodyText  String?
  variables Json     @default("[]")
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("email_templates")
}

model CampaignTemplate {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @db.Uuid
  name      String
  type      CampaignType
  structure Json     // sequence of messages
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("campaign_templates")
}

// ============================================================
// 8. FILE STORAGE (S3 METADATA)
// ============================================================

model File {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String   @db.Uuid
  userId      String   @db.Uuid
  fileName    String
  fileType    String
  s3Key       String
  s3Bucket    String   @default("contact360-uploads")
  mimeType    String?
  sizeBytes   BigInt?
  rowCount    Int?
  columnCount Int?
  status      String   @default("uploaded")
  createdAt   DateTime @default(now())

  org      Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [userId], references: [id])
  columns  FileColumn[]
  analysis FileAnalysis?
  jobs     Job[]

  @@index([orgId, userId])
  @@map("files")
}

model FileColumn {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fileId     String @db.Uuid
  columnName String
  dataType   String
  sampleData Json?
  isRequired Boolean @default(false)
  mappedTo   String? // CRM field it maps to

  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@map("file_columns")
}

model FileAnalysis {
  id      String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fileId  String @unique @db.Uuid
  summary Json

  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@map("file_analysis")
}

// ============================================================
// 9. JOB SYSTEM (IMPORT / EXPORT / ENRICH)
// ============================================================

model Job {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String    @db.Uuid
  type        JobType
  status      JobStatus @default(PENDING)
  progress    Int       @default(0)
  fileId      String?   @db.Uuid
  metadata    Json      @default("{}")
  errorMsg    String?
  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  file File?        @relation(fields: [fileId], references: [id])
  logs JobLog[]

  @@index([orgId, status])
  @@map("jobs")
}

model JobLog {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  jobId     String      @db.Uuid
  message   String
  level     JobLogLevel @default(INFO)
  metadata  Json        @default("{}")
  createdAt DateTime    @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@map("job_logs")
}

// ============================================================
// 10. BQL CONNECTOR (QUERY LOGS)
// ============================================================

model BqlQuery {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId      String   @db.Uuid
  userId     String   @db.Uuid
  query      String
  parsedAst  Json?
  resultCount Int?
  durationMs Int?
  executedAt DateTime @default(now())

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id])
  exports BqlExport[]

  @@index([orgId, executedAt(sort: Desc)])
  @@map("bql_queries")
}

model BqlExport {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  queryId   String   @db.Uuid
  fileId    String?  @db.Uuid
  format    String   @default("csv")
  createdAt DateTime @default(now())

  query BqlQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)

  @@map("bql_exports")
}

// ============================================================
// 11. AI + MCP SYSTEM
// ============================================================

model AiQuery {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String   @db.Uuid
  userId       String   @db.Uuid
  sessionId    String?
  query        String
  intent       String?
  response     String?
  toolsCalled  Json     @default("[]")
  promptTokens Int?
  compTokens   Int?
  costUsd      Decimal? @db.Decimal(8, 6)
  latencyMs    Int?
  createdAt    DateTime @default(now())

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id])

  @@index([orgId, createdAt(sort: Desc)])
  @@map("ai_queries")
}

model AiAction {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String        @db.Uuid
  userId       String?       @db.Uuid
  aiQueryId    String?       @db.Uuid
  actionType   String        // send_campaign, update_contact, add_to_list
  payload      Json
  preview      Json?
  riskLevel    String?       // low, medium, high
  status       AiActionStatus @default(PENDING_APPROVAL)
  approvedAt   DateTime?
  rejectedAt   DateTime?
  executedAt   DateTime?
  errorMsg     String?
  createdAt    DateTime      @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, status])
  @@map("ai_actions")
}

model AiMemory {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @db.Uuid
  userId    String?  @db.Uuid
  scope     String   // org | user
  key       String
  value     String
  metadata  Json     @default("{}")
  expiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, scope, key])
  @@index([orgId])
  @@map("ai_memories")
}

// ============================================================
// 12. INTEGRATIONS
// ============================================================

model Integration {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String            @db.Uuid
  type      IntegrationType
  status    IntegrationStatus @default(PENDING_AUTH)
  config    Json              @default("{}")
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, type])
  @@index([orgId])
  @@map("integrations")
}

model ProviderAccount {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId      String   @db.Uuid
  provider   String   // ses, twilio, sendgrid, hunter, apollo
  label      String?
  apiKeyEnc  String   // AES-256 encrypted
  config     Json     @default("{}")
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, provider, label])
  @@index([orgId])
  @@map("provider_accounts")
}

// ============================================================
// 13. EXTENSION DATA (SCRAPED)
// ============================================================

model ExtensionEvent {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId      String   @db.Uuid
  userId     String   @db.Uuid
  contactId  String?  @db.Uuid
  source     String   // linkedin, gmail, sales_navigator
  rawData    Json
  processed  Boolean  @default(false)
  processedAt DateTime?
  createdAt  DateTime @default(now())

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id])
  contact Contact?     @relation(fields: [contactId], references: [id])

  @@index([orgId, processed])
  @@map("extension_events")
}

// ============================================================
// 14. AUDIT LOG (APPEND-ONLY)
// ============================================================

model AuditLog {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId      String        @db.Uuid
  userId     String?       @db.Uuid
  apiKeyId   String?       @db.Uuid
  action     String
  resource   String?
  resourceId String?
  ipAddress  String?
  userAgent  String?
  requestId  String?       @db.Uuid
  severity   AuditSeverity @default(INFO)
  metadata   Json          @default("{}")
  createdAt  DateTime      @default(now())

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User?        @relation(fields: [userId], references: [id])

  @@index([orgId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([resource, resourceId])
  @@map("audit_logs")
}
