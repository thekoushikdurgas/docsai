{
  "info": {
    "_postman_id": "resume-module-graphql",
    "name": "GraphQL – Resume Module",
    "description": "Resume AI (root field `resume`): list/get resumes; saveResume, deleteResume. Proxied to resumeai — requires RESUME_AI / related env on the API server.\n\nVariables: baseUrl, accessToken, resumeId (optional for single-resume ops).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "resumeId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Queries",
      "item": [
        {
          "name": "resumes",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query ListResumes { resume { resumes { id userId resumeData createdAt updatedAt } } }\",\n  \"variables\": {}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            },
            "description": "List resume documents for the authenticated user."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const rows = pm.response.json()?.data?.resume?.resumes;",
                  "  if (Array.isArray(rows) && rows[0]?.id) {",
                  "    pm.environment.set('resumeId', rows[0].id);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "resume (by id)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query GetResume($id: ID!) { resume { resume(id: $id) { id userId resumeData createdAt updatedAt } } }\",\n  \"variables\": { \"id\": \"{{resumeId}}\" }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            },
            "description": "Get one resume by id (must belong to the current user). Set resumeId in the environment."
          }
        }
      ]
    },
    {
      "name": "Mutations",
      "item": [
        {
          "name": "saveResume (create)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation SaveResume($input: SaveResumeInput!) { resume { saveResume(input: $input) { id userId resumeData createdAt updatedAt } } }\",\n  \"variables\": {\n    \"input\": {\n      \"resumeData\": { \"title\": \"My resume\", \"sections\": [] }\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            },
            "description": "Create a new resume (omit id). For update, include id matching an existing resume."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const id = pm.response.json()?.data?.resume?.saveResume?.id;",
                  "  if (id) pm.environment.set('resumeId', id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "deleteResume",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation DeleteResume($id: ID!) { resume { deleteResume(id: $id) } }\",\n  \"variables\": { \"id\": \"{{resumeId}}\" }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            },
            "description": "Delete a resume by id."
          }
        }
      ]
    }
  ]
}