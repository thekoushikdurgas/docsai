{
  "info": {
    "_postman_id": "ec2-s3storage-server-contact360",
    "name": "EC2 s3storage.server (Gin API)",
    "description": "Postman collection for EC2/s3storage.server Gin routes.\n\nAuth: All routes except /health and /health/ready require X-API-Key header (or ?api_key= query param).\n\nError envelope: All errors return {\"error\": string, \"code\": string, \"request_id\": string, \"aws_error_code\"?: string, \"details\"?: any}\n\nUpload flow:\n1. POST /api/v1/uploads/initiate-csv  → upload_id\n2. GET  /api/v1/uploads/:id/parts/:n  → presigned PUT URL per part\n3. PUT each presigned URL directly to S3 (from client)\n4. POST /api/v1/uploads/:id/complete  → {bucket, key, metadata_queued}\n   OR  DELETE /api/v1/uploads/:id/abort  to cancel",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /api/v1/health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{s3storage_base_url}}/api/v1/health",
              "host": ["{{s3storage_base_url}}"],
              "path": ["api", "v1", "health"]
            },
            "description": "Liveness probe. No auth required."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\"status\": \"ok\"}",
              "originalRequest": {
                "method": "GET",
                "url": { "raw": "{{s3storage_base_url}}/api/v1/health" }
              }
            }
          ]
        },
        {
          "name": "GET /api/v1/health/ready",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{s3storage_base_url}}/api/v1/health/ready",
              "host": ["{{s3storage_base_url}}"],
              "path": ["api", "v1", "health", "ready"]
            },
            "description": "Readiness probe. Checks S3 bucket access and Redis PING. No auth required."
          },
          "response": [
            {
              "name": "200 Ready",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\"ready\": true}",
              "originalRequest": {
                "method": "GET",
                "url": { "raw": "{{s3storage_base_url}}/api/v1/health/ready" }
              }
            },
            {
              "name": "503 Redis unavailable",
              "status": "Service Unavailable",
              "code": 503,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\"error\": \"redis unavailable\", \"code\": \"SERVICE_UNAVAILABLE\", \"request_id\": \"...\", \"details\": {\"redis_error\": \"dial tcp: connection refused\"}}",
              "originalRequest": {
                "method": "GET",
                "url": { "raw": "{{s3storage_base_url}}/api/v1/health/ready" }
              }
            },
            {
              "name": "503 S3 unreachable",
              "status": "Service Unavailable",
              "code": 503,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\"error\": \"operation error S3: HeadBucket, ...\", \"code\": \"SERVICE_UNAVAILABLE\", \"request_id\": \"...\"}",
              "originalRequest": {
                "method": "GET",
                "url": { "raw": "{{s3storage_base_url}}/api/v1/health/ready" }
              }
            }
          ]
        }
      ]
    },
