{
  "info": {
    "name": "EC2 job.server (Contact360)",
    "description": "HTTP collection for [`EC2/job.server`](../../../EC2/job.server) (Gin, Mongo, Asynq). Parity with gateway [`JobServerClient`](../../../contact360.io/api/app/clients/job_server_client.py) and [`ROUTE-CLIENT-MATRIX`](../endpoints/job.server/ROUTE-CLIENT-MATRIX.md).\n\n**Connectra read-through** (`/jobs/.../company`, `/jobs/.../contacts`, `/companies/.../record`, `/companies/.../contacts`): proxies **sync.server** when `CONNECTRA_BASE_URL` + `CONNECTRA_API_KEY` are set. **503** if unset; **502** on upstream HTTP errors; job routes **404** if job missing, **409** if job has no `company_uuid`; company **404** if Connectra has no company.\n\n**Base URL**: `{{base_url}}` (default `http://localhost:9900`).\n\n**Auth**: `X-API-Key` = `API_KEY` when non-empty. If `API_KEY` is empty, `/api/v1` does not require a key. `GET /health` is unauthenticated.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:9900" },
    { "key": "api_key", "value": "change-me" },
    { "key": "company_uuid", "value": "00000000-0000-0000-0000-000000000000" },
    { "key": "linkedin_job_id", "value": "example-linkedin-job-id" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/health"
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "GET /api/v1/jobs",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/jobs?limit=25&offset=0",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs"],
              "query": [
                { "key": "limit", "value": "25" },
                { "key": "offset", "value": "0" },
                { "key": "title", "value": "", "disabled": true },
                { "key": "company", "value": "", "disabled": true },
                { "key": "location", "value": "", "disabled": true },
                { "key": "employment_type", "value": "", "disabled": true },
                { "key": "seniority", "value": "", "description": "Case-insensitive regex on Mongo seniority_level", "disabled": true },
                { "key": "function", "value": "", "description": "Case-insensitive regex on Mongo function_category_v2", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "GET /api/v1/jobs/stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": "{{base_url}}/api/v1/jobs/stats"
          }
        },
        {
          "name": "GET /api/v1/jobs/{linkedinJobId}",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/jobs/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs", ":id"],
              "variable": [{ "key": "id", "value": "{{linkedin_job_id}}" }]
            }
          }
        }
      ]
    },
    {
      "name": "Runs",
      "item": [
        {
          "name": "GET /api/v1/runs",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/runs?limit=50",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "runs"],
              "query": [{ "key": "limit", "value": "50" }]
            }
          }
        },
        {
          "name": "GET /api/v1/runs/{runId}",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/runs/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "runs", ":id"],
              "variable": [{ "key": "id", "value": "apify-run-id" }]
            }
          }
        },
        {
          "name": "POST /api/v1/runs (enqueue scrape)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-API-Key", "value": "{{api_key}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trigger\": \"postman\",\n  \"SCRAPE_URLS\": [\n    \"https://www.linkedin.com/jobs/search/?keywords=go&position=1&pageNum=0\"\n  ],\n  \"SCRAPE_COUNT\": 100\n}\n"
            },
            "url": "{{base_url}}/api/v1/runs"
          }
        }
      ]
    },
    {
      "name": "Companies",
      "item": [
        {
          "name": "GET /api/v1/companies",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/companies?limit=100",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "companies"],
              "query": [{ "key": "limit", "value": "100" }]
            }
          }
        },
        {
          "name": "GET /api/v1/companies/{companyUuid}/jobs",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/companies/{{company_uuid}}/jobs?limit=50",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "companies", "{{company_uuid}}", "jobs"],
              "query": [{ "key": "limit", "value": "50" }]
            }
          }
        }
      ]
    },
    {
      "name": "Connectra (sync via job.server)",
      "description": "Handlers: `job_connectra_handlers.go`, `company_connectra_handlers.go`. Query: `page` (default 1, max 10), `limit` (default 25, max 100), `populate_company` (default true). Job contacts: `include_poster` (default true).",
      "item": [
        {
          "name": "GET /api/v1/jobs/{id}/contacts",
          "request": {
            "description": "VQL contact search for the job's `company_uuid`. **409** if job has no company link. Response `data`: `contacts`, `job_poster_contact`, `total`.",
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/jobs/:id/contacts?page=1&limit=25&populate_company=true&include_poster=true",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs", ":id", "contacts"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "25" },
                { "key": "populate_company", "value": "true" },
                { "key": "include_poster", "value": "true" }
              ],
              "variable": [{ "key": "id", "value": "{{linkedin_job_id}}" }]
            }
          }
        },
        {
          "name": "GET /api/v1/jobs/{id}/company",
          "request": {
            "description": "Connectra `GET /companies/{uuid}` for the job's `company_uuid`. Response `data`: `{ job, company }`. **409** if no `company_uuid` on job.",
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/jobs/:id/company",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs", ":id", "company"],
              "variable": [{ "key": "id", "value": "{{linkedin_job_id}}" }]
            }
          }
        },
        {
          "name": "GET /api/v1/companies/{company_uuid}/contacts",
          "request": {
            "description": "VQL contacts for Connectra company UUID (path param matches Gin `:company_uuid`). Response `data`: `contacts`, `total`.",
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/companies/:company_uuid/contacts?page=1&limit=25&populate_company=true",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "companies", ":company_uuid", "contacts"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "25" },
                { "key": "populate_company", "value": "true" }
              ],
              "variable": [{ "key": "company_uuid", "value": "{{company_uuid}}" }]
            }
          }
        },
        {
          "name": "GET /api/v1/companies/{company_uuid}/record",
          "request": {
            "description": "Single Connectra company record. Response `data` is the company object.",
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/companies/:company_uuid/record",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "companies", ":company_uuid", "record"],
              "variable": [{ "key": "company_uuid", "value": "{{company_uuid}}" }]
            }
          }
        }
      ]
    }
  ]
}
