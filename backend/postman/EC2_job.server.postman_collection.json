{
  "info": {
    "name": "EC2 job.server (Contact360)",
    "description": "HTTP collection for [`EC2/job.server`](../../../EC2/job.server) (Gin, Mongo, Asynq). Core routes match [`JobServerClient`](../../../contact360.io/api/app/clients/job_server_client.py). **Connectra** folder: read-through to **sync.server** — requires `CONNECTRA_BASE_URL` and `CONNECTRA_API_KEY` on job.server (otherwise **503**); not yet in the Python client.\n\n**Base URL**: `{{base_url}}` (default `http://localhost:9900`).\n\n**Auth**: `X-API-Key` = `API_KEY` when non-empty. If `API_KEY` is empty, `/api/v1` does not require a key. `GET /health` is always unauthenticated.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:9900" },
    { "key": "api_key", "value": "change-me" },
    { "key": "company_uuid", "value": "00000000-0000-0000-0000-000000000000" },
    { "key": "linkedin_job_id", "value": "example-linkedin-job-id" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/health"
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "GET /api/v1/jobs",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/jobs?limit=25&offset=0",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs"],
              "query": [
                { "key": "limit", "value": "25" },
                { "key": "offset", "value": "0" },
                { "key": "title", "value": "", "disabled": true },
                { "key": "company", "value": "", "disabled": true },
                { "key": "location", "value": "", "disabled": true },
                { "key": "employment_type", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "GET /api/v1/jobs/stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": "{{base_url}}/api/v1/jobs/stats"
          }
        },
        {
          "name": "GET /api/v1/jobs/{linkedinJobId}",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/jobs/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs", ":id"],
              "variable": [{ "key": "id", "value": "example-job-id" }]
            }
          }
        }
      ]
    },
    {
      "name": "Runs",
      "item": [
        {
          "name": "GET /api/v1/runs",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/runs?limit=50",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "runs"],
              "query": [{ "key": "limit", "value": "50" }]
            }
          }
        },
        {
          "name": "GET /api/v1/runs/{runId}",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/runs/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "runs", ":id"],
              "variable": [{ "key": "id", "value": "apify-run-id" }]
            }
          }
        },
        {
          "name": "POST /api/v1/runs (enqueue scrape)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-API-Key", "value": "{{api_key}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trigger\": \"postman\",\n  \"SCRAPE_URLS\": [\n    \"https://www.linkedin.com/jobs/search/?keywords=go&position=1&pageNum=0\"\n  ],\n  \"SCRAPE_COUNT\": 100\n}\n"
            },
            "url": "{{base_url}}/api/v1/runs"
          }
        }
      ]
    },
    {
      "name": "Companies",
      "item": [
        {
          "name": "GET /api/v1/companies",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/companies?limit=100",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "companies"],
              "query": [{ "key": "limit", "value": "100" }]
            }
          }
        },
        {
          "name": "GET /api/v1/companies/{companyUuid}/jobs",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/companies/{{company_uuid}}/jobs?limit=50",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "companies", "{{company_uuid}}", "jobs"],
              "query": [{ "key": "limit", "value": "50" }]
            }
          }
        }
      ]
    },
    {
      "name": "Connectra (sync via job.server)",
      "item": [
        {
          "name": "GET /api/v1/jobs/{id}/contacts",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/jobs/:id/contacts?page=1&limit=25&populate_company=true&include_poster=true",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs", ":id", "contacts"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "25" },
                { "key": "populate_company", "value": "true" },
                { "key": "include_poster", "value": "true" }
              ],
              "variable": [{ "key": "id", "value": "{{linkedin_job_id}}" }]
            }
          }
        },
        {
          "name": "GET /api/v1/jobs/{id}/company",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/jobs/:id/company",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs", ":id", "company"],
              "variable": [{ "key": "id", "value": "{{linkedin_job_id}}" }]
            }
          }
        },
        {
          "name": "GET /api/v1/companies/{companyUuid}/contacts",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/companies/:companyUuid/contacts?page=1&limit=25&populate_company=true",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "companies", ":companyUuid", "contacts"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "25" },
                { "key": "populate_company", "value": "true" }
              ],
              "variable": [{ "key": "companyUuid", "value": "{{company_uuid}}" }]
            }
          }
        },
        {
          "name": "GET /api/v1/companies/{companyUuid}/record",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/companies/:companyUuid/record",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "companies", ":companyUuid", "record"],
              "variable": [{ "key": "companyUuid", "value": "{{company_uuid}}" }]
            }
          }
        }
      ]
    }
  ]
}
