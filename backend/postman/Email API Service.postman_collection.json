							{
								"key": "X-API-Key",
								"value": "{{api_key}}",
								"description": "API key for authentication"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\",\n  \"domain\": \"example.com\",\n  \"website\": null\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/email/single/",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"email",
								"single",
								""
							]
						},
						"description": "Find single email by contact name and company domain. This is a simplified version that returns the first email found."
					},
					"response": []
				}
			],
			"description": "Email finder endpoints for finding emails by contact name and company domain"
