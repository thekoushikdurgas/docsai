{
  "info": {
    "_postman_id": "ec2-sync-server-connectra-contact360",
    "name": "EC2 sync.server (Connectra API)",
    "description": "REST API for EC2/sync.server (Connectra). Every route including GET /health requires X-API-Key matching API_KEY. Rate limit: 429 when MAX_REQUESTS_PER_MINUTE bucket is empty (middleware.RateLimiter). Default port 8000 (PORT). Full contract: docs/backend/micro.services.apis/connectra.api.md",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{connectra_api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{connectra_base_url}}/health",
              "host": ["{{connectra_base_url}}"],
              "path": ["health"]
            },
            "description": "Returns status, version, uptime_seconds, service=connectra, diagnostics (database, search_engine). API key is required by global middleware in cmd/server.go."
          },
          "response": []
        }
      ]
    },
