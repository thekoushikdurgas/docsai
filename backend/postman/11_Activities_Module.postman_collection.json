{
    "info": {
        "_postman_id": "activities-module-graphql",
        "name": "GraphQL – Activities Module",
        "description": "Activities: activities (list with filters), activityStats. No mutations. Variables: use camelCase (limit, offset, serviceType, actionType, startDate, endDate). See sql/apis/11_ACTIVITIES_MODULE.md (Queries – parameters and variable types).",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:8000"
        },
        {
            "key": "accessToken",
            "value": ""
        }
    ],
    "item": [
        {
            "name": "Queries",
            "item": [
                {
                    "name": "activities",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"query\":\"query GetActivities($filters: ActivityFilterInput) { activities { activities(filters: $filters) { items { id serviceType actionType status resultCount createdAt } total limit offset hasNext hasPrevious } } }\",\"variables\":{\"filters\":{\"limit\":50,\"offset\":0}}}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/graphql",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "graphql"
                            ]
                        }
                    }
                },
                {
                    "name": "activityStats",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"query\":\"query GetActivityStats($filters: ActivityStatsInput) { activities { activityStats(filters: $filters) { totalActivities byServiceType byActionType byStatus recentActivities } } }\",\"variables\":{}}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/graphql",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "graphql"
                            ]
                        }
                    }
                }
            ]
        }
    ]
}