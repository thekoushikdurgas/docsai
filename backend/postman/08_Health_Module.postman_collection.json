{
  "info": {
    "_postman_id": "health-module-graphql",
    "name": "GraphQL – Health Module",
    "description": "Health checks: GraphQL field `health` (apiMetadata, apiHealth, vqlHealth, vqlStats, performanceStats) and REST routes on the same baseUrl (GET /health, /health/db, /health/logging, /health/slo, /health/token-blacklist, GET /).\n\nvqlHealth / vqlStats: authenticated. performanceStats: SuperAdmin.\n\nSee contact360.io/api app/main.py for REST handlers.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000"
    },
    {
      "key": "accessToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "GraphQL",
      "item": [
        {
          "name": "apiMetadata (no auth)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query { health { apiMetadata { name version docs } } }\",\n  \"variables\": {}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            }
          }
        },
        {
          "name": "apiHealth (no auth)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query { health { apiHealth { status environment } } }\",\n  \"variables\": {}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            }
          }
        },
        {
          "name": "vqlHealth",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query { health { vqlHealth { connectraEnabled connectraStatus connectraBaseUrl connectraDetails { status version uptime } connectraError } } }\",\n  \"variables\": {}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            }
          }
        },
        {
          "name": "vqlStats",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query { health { vqlStats { message note } } }\",\n  \"variables\": {}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            }
          }
        },
        {
          "name": "performanceStats (SuperAdmin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query { health { performanceStats { cache { enabled hits misses hitRate } database { status poolSize } s3 { status bucket region } } } }\",\n  \"variables\": {}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "REST",
      "item": [
        {
          "name": "GET / (root)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                ""
              ]
            },
            "description": "Returns graphql_endpoint and version info."
          }
        },
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          }
        },
        {
          "name": "GET /health/db",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health/db",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health",
                "db"
              ]
            }
          }
        },
        {
          "name": "GET /health/logging",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health/logging",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health",
                "logging"
              ]
            }
          }
        },
        {
          "name": "GET /health/slo",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health/slo",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health",
                "slo"
              ]
            }
          }
        },
        {
          "name": "GET /health/token-blacklist",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health/token-blacklist",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health",
                "token-blacklist"
              ]
            }
          }
        }
      ]
    }
  ]
}