{
  "info": {
    "_postman_id": "s3-module-graphql",
    "name": "GraphQL - S3 Module",
    "description": "Root field `s3`. Flow: initiateCsvUpload -> upload.presignedUrl + registerPart -> completeCsvUpload.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "fileKey",
      "value": ""
    },
    {
      "key": "uploadId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Queries",
      "item": [
        {
          "name": "s3Files",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query S3Files($prefix: String) { s3 { s3Files(prefix: $prefix) { files { key filename size lastModified contentType } total bucketDisplayName } } }\",\n  \"variables\": {\n    \"prefix\": \"upload/\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            }
          }
        },
        {
          "name": "s3FileData",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query S3Data($fileKey: String!, $limit: Int!, $offset: Int) { s3 { s3FileData(fileKey: $fileKey, limit: $limit, offset: $offset) { fileKey rows { data } limit offset totalRows } } }\",\n  \"variables\": {\n    \"fileKey\": \"{{fileKey}}\",\n    \"limit\": 100,\n    \"offset\": 0\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            }
          }
        },
        {
          "name": "s3FileInfo",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query S3Info($fileKey: String!) { s3 { s3FileInfo(fileKey: $fileKey) { key filename size lastModified contentType } } }\",\n  \"variables\": {\n    \"fileKey\": \"{{fileKey}}\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            }
          }
        },
        {
          "name": "s3FileDownloadUrl",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query S3Download($fileKey: String!, $expiresIn: Int) { s3 { s3FileDownloadUrl(fileKey: $fileKey, expiresIn: $expiresIn) { downloadUrl expiresIn } } }\",\n  \"variables\": {\n    \"fileKey\": \"{{fileKey}}\",\n    \"expiresIn\": 3600\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            }
          }
        },
        {
          "name": "s3FileSchema",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query S3Schema($fileKey: String!) { s3 { s3FileSchema(fileKey: $fileKey) { name type nullable } } }\",\n  \"variables\": {\n    \"fileKey\": \"{{fileKey}}\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            }
          }
        },
        {
          "name": "s3FileStats",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query S3Stats($fileKey: String!) { s3 { s3FileStats(fileKey: $fileKey) { rowCount columns } } }\",\n  \"variables\": {\n    \"fileKey\": \"{{fileKey}}\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            }
          }
        },
        {
          "name": "s3BucketMetadata",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query { s3 { s3BucketMetadata } }\",\n  \"variables\": {}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Mutations",
      "item": [
        {
          "name": "initiateCsvUpload",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation InitCsv($input: InitiateCsvUploadInput!) { s3 { initiateCsvUpload(input: $input) { uploadId fileKey s3UploadId chunkSize numParts } } }\",\n  \"variables\": {\n    \"input\": {\n      \"filename\": \"export.csv\",\n      \"fileSize\": 1048576\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            }
          }
        },
        {
          "name": "completeCsvUpload",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation CompleteCsv($input: CompleteUploadInput!) { s3 { completeCsvUpload(input: $input) { status fileKey s3Url location } } }\",\n  \"variables\": {\n    \"input\": {\n      \"uploadId\": \"{{uploadId}}\"\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            }
          }
        },
        {
          "name": "deleteFile",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation DelFile($fileKey: String!) { s3 { deleteFile(fileKey: $fileKey) } }\",\n  \"variables\": {\n    \"fileKey\": \"{{fileKey}}\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            }
          }
        }
      ]
    }
  ]
}