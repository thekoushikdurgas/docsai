    {
      "name": "Email Finder",
      "item": [
        {
          "name": "Find Emails",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}",
                "description": "API key for authentication"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"first_name\": \"Vivek\",\n    \"last_name\": \"Ray\", \n    \"domain\": \"cyble.com\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/email/finder/?first_name=Andrea&last_name=Willman&domain=teamsoftware.com",
              "host": ["{{base_url}}"],
              "path": ["email", "finder", ""],
              "query": [
                {
                  "key": "first_name",
                  "value": "Andrea",
                  "description": "Contact first name"
                },
                {
                  "key": "last_name",
                  "value": "Willman",
                  "description": "Contact last name"
                },
                {
                  "key": "domain",
                  "value": "teamsoftware.com",
                  "description": "Company domain or website URL"
                }
              ]
            },
            "description": "Find emails by contact name and company domain. Searches for contacts matching the provided first name and last name whose company website domain matches the provided domain/website."
          },
          "response": []
        },
        {
          "name": "Find Bulk Emails",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}",
                "description": "API key for authentication"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"first_name\": \"Karen\",\n      \"last_name\": \"Childs\",\n      \"domain\": \"premiertm.com\"\n    },\n    {\n      \"first_name\": \"raj\",\n      \"last_name\": \"roy\",\n      \"domain\": \"gmail.com\"\n    },\n    {\n      \"first_name\": \"Ayan\",\n      \"last_name\": \"Saha\",\n      \"domain\": \"piamamedialabs.com\"\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/email/finder/bulk",
              "host": ["{{base_url}}"],
              "path": ["email", "finder", "bulk"]
            },
            "description": "Find emails for multiple contacts in bulk (synchronous, max 50 items). Returns results for each contact."
          },
          "response": []
        },
        {
          "name": "S3 Finder Job",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-API-Key",
                "value": "{{api_key}}",
                "description": "API key for authentication"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"s3_bucket\": \"appointment360uploads\",\n  \"input_csv_key\": \"1ccb78d9-b7bb-4dea-b1d4-2ca9f62d3053/upload/100_test.csv\",\n  \"output_prefix\": \"1ccb78d9-b7bb-4dea-b1d4-2ca9f62d3053/exports/email_export\",\n  \"csv_columns\": {\n    \"first_name\": \"First Name\",\n    \"last_name\": \"Last Name\",\n    \"domain\": \"Website\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/email/finder/s3",
              "host": ["{{base_url}}"],
              "path": ["email", "finder", "s3"]
            },
            "description": "Create an async job to find emails from a CSV file stored in S3. Streams CSV rows and processes each row to find emails. Results are merged back into a new CSV."
          },
          "response": []
        }
      ],
      "description": "Email finder endpoints for finding emails by contact name and company domain"
    },
