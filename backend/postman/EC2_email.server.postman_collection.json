    {
      "name": "Jobs",
      "item": [
        {
          "name": "List Jobs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}",
                "description": "API key for authentication"
              }
            ],
            "url": {
              "raw": "{{base_url}}/jobs",
              "host": ["{{base_url}}"],
              "path": ["jobs"]
            },
            "description": "List the last 50 jobs with their status, progress, and metadata."
          },
          "response": []
        },
        {
          "name": "Job Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}",
                "description": "API key for authentication"
              }
            ],
            "url": {
              "raw": "{{base_url}}/jobs/{{job_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["jobs", "{{job_id}}", "status"]
            },
            "description": "Get detailed status of a specific job including progress, results, and completion state."
          },
          "response": []
        },
        {
          "name": "Pause Job",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}",
                "description": "API key for authentication"
              }
            ],
            "url": {
              "raw": "{{base_url}}/jobs/{{job_id}}/pause",
              "host": ["{{base_url}}"],
              "path": ["jobs", "{{job_id}}", "pause"]
            },
            "description": "Pause a running job. Workers will stop processing tasks for this job. Use Resume Job to continue."
          },
          "response": []
        },
        {
          "name": "Resume Job",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}",
                "description": "API key for authentication"
              }
            ],
            "url": {
              "raw": "{{base_url}}/jobs/{{job_id}}/resume",
              "host": ["{{base_url}}"],
              "path": ["jobs", "{{job_id}}", "resume"]
            },
            "description": "Resume a paused job. Workers will continue processing pending tasks."
          },
          "response": []
        },
        {
          "name": "Terminate Job",
          "request": {
            "method": "POST",
