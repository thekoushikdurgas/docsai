{
  "info": {
    "_postman_id": "notifications-module-graphql",
    "name": "GraphQL – Notifications Module",
    "description": "Root field `notifications`. Queries: notifications, notification, unreadCount, notificationPreferences. Mutations: markNotificationAsRead, markNotificationsAsRead, deleteNotifications, updateNotificationPreferences.\n\nThere is no mark-all or single-delete mutation in the API — use markNotificationsAsRead / deleteNotifications with id list from List notifications.\n\nEnv: notificationId, accessToken, baseUrl.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "notificationId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Queries",
      "item": [
        {
          "name": "notifications",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query ListNotifications($filters: NotificationFilterInput) { notifications { notifications(filters: $filters) { items { id type priority title message read readAt createdAt } pageInfo { total limit offset hasNext hasPrevious } } } }\",\n  \"variables\": {\n    \"filters\": {\n      \"unreadOnly\": false,\n      \"limit\": 20,\n      \"offset\": 0\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            }
          }
        },
        {
          "name": "notification",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query GetNotification($notificationId: ID!) { notifications { notification(notificationId: $notificationId) { id type priority title message read readAt createdAt metadata } } }\",\n  \"variables\": { \"notificationId\": \"{{notificationId}}\" }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            }
          }
        },
        {
          "name": "unreadCount",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query GetUnreadCount { notifications { unreadCount { count } } }\",\n  \"variables\": {}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            }
          }
        },
        {
          "name": "notificationPreferences",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query GetPreferences { notifications { notificationPreferences { emailDigest newLeads securityAlerts marketing billingUpdates pushEnabled emailEnabled } } }\",\n  \"variables\": {}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Mutations",
      "item": [
        {
          "name": "markNotificationAsRead",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation MarkAsRead($notificationId: ID!) { notifications { markNotificationAsRead(notificationId: $notificationId) { id read readAt } } }\",\n  \"variables\": { \"notificationId\": \"{{notificationId}}\" }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            }
          }
        },
        {
          "name": "markNotificationsAsRead",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation MarkMultipleAsRead($input: MarkReadInput!) { notifications { markNotificationsAsRead(input: $input) { count } } }\",\n  \"variables\": { \"input\": { \"notificationIds\": [\"{{notificationId}}\"] } }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            },
            "description": "Replace notificationIds with real ids, e.g. [\"1\",\"2\"]."
          }
        },
        {
          "name": "deleteNotifications",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation DeleteNotifications($input: DeleteNotificationsInput!) { notifications { deleteNotifications(input: $input) { count } } }\",\n  \"variables\": { \"input\": { \"notificationIds\": [\"{{notificationId}}\"] } }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            }
          }
        },
        {
          "name": "updateNotificationPreferences",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation UpdatePreferences($input: UpdateNotificationPreferencesInput!) { notifications { updateNotificationPreferences(input: $input) { emailDigest newLeads securityAlerts marketing billingUpdates pushEnabled emailEnabled } } }\",\n  \"variables\": {\n    \"input\": {\n      \"emailDigest\": true,\n      \"newLeads\": true,\n      \"securityAlerts\": true,\n      \"marketing\": false,\n      \"billingUpdates\": true,\n      \"pushEnabled\": false,\n      \"emailEnabled\": true\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            }
          }
        }
      ]
    }
  ]
}