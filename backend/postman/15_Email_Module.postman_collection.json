              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query { email { verifyexportEmail { message endpoint } } }\",\n  \"variables\": {}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Mutations",
      "item": [
        {
          "name": "addEmailPattern",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation AddPattern($input: EmailPatternAddInput!) { email { addEmailPattern(input: $input) { uuid companyUuid patternFormat patternString domain contactCount createdAt } } }\",\n  \"variables\": {\n    \"input\": {\n      \"companyUuid\": \"{{companyUuid}}\",\n      \"email\": \"john.doe@example.com\",\n      \"firstName\": \"John\",\n      \"lastName\": \"Doe\",\n      \"domain\": \"example.com\"\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            }
          }
        },
        {
          "name": "addEmailPatternBulk",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation AddPatternBulk($input: EmailPatternBulkAddInput!) { email { addEmailPatternBulk(input: $input) { results { uuid companyUuid domain } success } } }\",\n  \"variables\": {\n    \"input\": {\n      \"items\": [\n        {\n          \"companyUuid\": \"{{companyUuid}}\",\n          \"email\": \"j@example.com\",\n          \"firstName\": \"J\",\n          \"lastName\": \"Doe\",\n          \"domain\": \"example.com\"\n        }\n      ]\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            }
          }
        },
        {
          "name": "createEmailFinderBulkJob",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation FinderBulkJob($input: BulkEmailFinderJobInput!) { email { createEmailFinderBulkJob(input: $input) { jobId queued statusUrl idempotentReplay success } } }\",\n  \"variables\": {\n    \"input\": {\n      \"items\": [\n        { \"firstName\": \"John\", \"lastName\": \"Doe\", \"domain\": \"example.com\" }\n      ]\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            }
          }
        },
        {
          "name": "createEmailFinderBulkJob (idempotencyKey)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation FinderBulkJob($input: BulkEmailFinderJobInput!) { email { createEmailFinderBulkJob(input: $input) { jobId queued statusUrl idempotentReplay success } } }\",\n  \"variables\": {\n    \"input\": {\n      \"items\": [\n        { \"firstName\": \"John\", \"lastName\": \"Doe\", \"domain\": \"example.com\" }\n      ],\n      \"idempotencyKey\": \"{{idempotencyKey}}\"\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": ["{{baseUrl}}"],
              "path": ["graphql"]
            },
            "description": "Set `idempotencyKey` in environment (non-empty) before run; matches email.server `X-Idempotency-Key` flow."
          }
        },
        {
          "name": "createEmailVerifyBulkJob",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation VerifyBulkJob($input: BulkEmailVerifyJobInput!) { email { createEmailVerifyBulkJob(input: $input) { jobId queued statusUrl idempotentReplay success } } }\",\n  \"variables\": { \"input\": { \"emails\": [\"a@example.com\"], \"provider\": \"truelist\" } }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            }
          }
        }
      ]
    }
  ]
