    {
      "id": "d3fc7b38-c89b-43eb-a9b9-b8ddfb6dcfd9",
      "name": "Rewrite Article",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "position": [
        848,
        208
      ],
      "parameters": {
        "text": "={{ $json.content }}",
        "options": {
          "systemMessage": "=You are an experienced journalist. Understand the content...\n以下の「元の記事」の内容を正確に理解し、その情報を元にして、次の構成に従った新しい解説記事を作成してください。\n記事全体のトーンは、中立的かつ客観的で、専門知識がない人にも分かりやすい言葉で書いてください。\n\n# 構成\n・【タイトル】記事の内容がすぐに分かり、読者の興味を引くようなタイトル\n・【導入】このニュースが「なぜ今、重要なのか」を1〜2文で簡潔に説明\n・【要点サマリー】元の記事の最も重要なポイントを3つの箇条書きでリストアップ\n・【背景と深掘り解説】この出来事が起きた背景や、関連する重要なキーワードについて、初心者にも理解できるように丁寧に解説\n・【今後の展望】このニュースが、今後どのような影響を与えうるか、考えられるいくつかの可能性を提示\n・【まとめ】記事全体の結論と、読者へのメッセージ\n\n\n"
        },
        "promptType": "define"
      },
      "typeVersion": 3
    },
    {
      "id": "097a85cb-590f-42d7-8e5f-a35815e8ece6",
      "name": "Extract Location",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "position": [
        1120,
        208
      ],
      "parameters": {
        "text": "={{ $('Limit Items').item.json.content }}\n\n最も重要だと思われる地名または施設名を一つだけ抽出し、その名称のみを出力してください。余計な説明は一切不要です。",
        "options": {
          "systemMessage": "From the text provided, extract only the single most important location name...\n\n例：清水寺、東京スカイツリー、道頓堀"
        },
        "promptType": "define"
      },
      "typeVersion": 3
    },
    {
      "id": "4b7e11eb-4c2b-4d5f-842c-884209635f3d",
      "name": "Translate Content",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "position": [
        1392,
        208
      ],
      "parameters": {
        "text": "=={{ $('Rewrite Article').item.json.output }}",
        "options": {
          "systemMessage": "You are a professional translator. Translate the input Japanese article into English, Chinese, and Korean...\n\n1. 英語 (English)\n2. 中国語 簡体字 (Chinese Simplified)\n3. 韓国語 (Korean)\n\n重要：\n必ず以下のJSON形式のデータのみを出力してください。余計な挨拶やMarkdown記号（```jsonなど）は一切書かないでください。\n\n{\n  \"en\": \"ここに英語の翻訳\",\n  \"zh\": \"ここに中国語の翻訳\",\n  \"ko\": \"ここに韓国語の翻訳\"\n}"
        },
        "promptType": "define"
      },
      "typeVersion": 3
    },
    {
      "id": "36bf6334-2cff-4c58-bb5f-6f84a5b90a3c",
      "name": "Format Data",
      "type": "n8n-nodes-base.code",
      "position": [
        1664,
        208
      ],
      "parameters": {
        "jsCode": "// -------------------------------------------------------\n// 【設定・準備】\n// -------------------------------------------------------\n// 前段のノードからデータを一括取得します。\n// ★重要：元データとして「Limit Items」ではなく「Filter Keywords」を使います。\n// これにより、除外された記事による順序ズレ（Index Misalignment）を完全に防げます。\nconst filteredItems = $('Filter Keywords').all();   // フィルタ通過済みの元記事データ\nconst aiAgentItems  = $('Rewrite Article').all();   // AI: 記事書き換えの結果\nconst locationItems = $('Extract Location').all();  // AI: 場所抽出の結果\n\n// -------------------------------------------------------\n// 【メイン処理】\n// 現在の入力（Translate Content）をループ処理します\n// -------------------------------------------------------\nreturn $input.all().map((item, index) => {\n  try {\n    // 1. インデックスを使った安全なデータの紐付け\n    // ---------------------------------------------------\n    // すべての処理は「Filter Keywords」を通過したリストに対して順に行われているため、\n    // index番号は完全に一致します。\n    const originalData = filteredItems[index].json;\n    \n    // AI抽出データがない場合のフォールバック（念のため）\n    const locationName = locationItems[index]?.json?.output || \"N/A\";\n    const rewriteTextRaw = aiAgentItems[index]?.json?.output || \"\";\n\n\n    // 2. 翻訳データ（JSON）のパース処理\n    // ---------------------------------------------------\n    // Translate Contentノードからの出力（翻訳JSON）を取得\n    const translationRaw = item.json.output || \"{}\";\n    \n    // デフォルト値の設定\n    let translations = { en: \"Translation Error\", zh: \"Translation Error\", ko: \"Translation Error\" };\n    \n    try {\n      // 生成AIが Markdown記号（```json ... ```）を付けてくることがあるため削除します\n      const cleanJsonStr = translationRaw.replace(/```json|```/g, '').trim();\n      translations = JSON.parse(cleanJsonStr);\n    } catch (e) {\n      console.log(\"Translation JSON Parse Error: \", e);\n      // エラー時はそのままテキストを入れるなど、柔軟に対応可能です\n    }\n\n\n    // 3. 記事本文の整形（Markdown記号の削除）\n    // ---------------------------------------------------\n    // Google SheetsやSlackで見やすくするため、Markdownの見出し(#)や強調(*)を削除\n    const cleanBody = rewriteTextRaw\n      .replace(/[#*]/g, '')     // # と * を削除\n      .replace(/\\n{3,}/g, '\\n\\n') // 3つ以上の連続改行を2つに詰める\n      .trim();\n\n\n    // 4. 要約（サマリー）の抽出\n    // ---------------------------------------------------\n    // 「Rewrite Article」が生成した【要点サマリー】の部分だけを抜き出します\n    let summary = \"\";\n    const summaryMatch = rewriteTextRaw.match(/(?:【要点サマリー】|【Key Points Summary】|【Summary】)([\\s\\S]*?)(?=【|$)/);\n    \n    if (summaryMatch && summaryMatch[1]) {\n      // 箇条書き記号や余計な改行を整理して、1行の文章にします\n      summary = summaryMatch[1]\n        .replace(/[・-]/g, '')\n        .replace(/\\n/g, ' ')\n        .trim();\n    } else {\n      // 万が一抽出できない場合は、記事の冒頭120文字を使用\n      summary = cleanBody.substring(0, 120) + \"...\";\n    }\n\n\n    // 5. データの結合と出力\n    // ---------------------------------------------------\n    // 扱いやすい1つのJSONオブジェクトにまとめます\n    return {\n      json: {\n        title:          originalData.title,    // 元記事のタイトル (RSS由来)\n        url:            originalData.link,     // 元記事のURL (RSS由来)\n        location:       locationName,          // 抽出した場所\n        short_summary:  summary,               // 生成した短い要約\n        original_clean: cleanBody,             // 読みやすく整形した日本語記事全文\n        \n        // 翻訳データを展開\n        en: translations.en,\n        zh: translations.zh,\n        ko: translations.ko\n      },\n      // ノード実行のペアリング情報を維持\n      pairedItem: item.pairedItem\n    };\n\n  } catch (error) {\n    // エラーハンドリング: 何か失敗してもワークフローを止めずエラーを出力\n    return {\n      json: {\n        error: \"Data Formatting Failed\",\n        message: error.message,\n        original_title: filteredItems[index]?.json?.title || \"Unknown\"\n      }\n    };\n  }\n});"
      },
      "typeVersion": 2
    },
