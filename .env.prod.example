# Contact360 DocsAI Admin — copy to `.env.prod` on EC2 (see deploy/README.md).

DJANGO_ENV=production

# Local dev: optional (defaults in development settings). Production/staging: required (32+ chars).
# SECRET_KEY=

DEBUG=False
# Production: comma-separated hosts — include EC2 IP and public hostname
ALLOWED_HOSTS=admin.contact360.io,34.201.10.84,localhost

# HTTPS behind nginx/certbot — enables secure session/CSRF cookies in production.py
SECURE_SSL_REDIRECT=true
CSRF_TRUSTED_ORIGINS=https://admin.contact360.io

# GraphQL gateway — HTTPS in production (see README.md)
GRAPHQL_URL=https://api.contact360.io/graphql
GRAPHQL_INTERNAL_TOKEN=

# Production: disable local Django staff fallback unless break-glass (default false in production.py)
# AUTH_FALLBACK_LOCAL=false

LOGS_API_URL=
LOGS_API_KEY=
S3STORAGE_API_URL=
S3STORAGE_API_KEY=
SCHEDULER_URL=
AI_API_URL=
AI_API_KEY=
EMAILCAMPAIGN_URL=

SESSION_COOKIE_AGE=86400
SESSION_COOKIE_SECURE=true

# Optional PostgreSQL (otherwise SQLite db.sqlite3)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# CONN_MAX_AGE=60

# Optional Redis cache
# USE_REDIS_CACHE=false
# REDIS_URL=redis://localhost:6379/0

# Optional Sentry
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# API hit tracking (documentation stats)
API_TRACKING_ENABLED=true
API_TRACKING_PATH_PREFIX=/api/v1/

DOCS_AGENT_VERSION=1.0.0
